<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="4dp">

    <!-- Sent Message Container (User) -->
    <LinearLayout
        android:id="@+id/layoutUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvMessageUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="64dp"
            android:background="@drawable/chat_bubble_sent"
            android:padding="12dp"
            android:text="User message"
            android:textColor="@color/white"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Received Message Container (Assistant) -->
    <LinearLayout
        android:id="@+id/layoutAssistant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:orientation="horizontal"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="64dp"
            android:background="@drawable/chat_bubble_received"
            android:padding="12dp"
            android:text="AI message"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>
