<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Info Banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/md_theme_primaryContainer"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvInfoTarea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_onPrimaryContainer"
                android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Título -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTitulo"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título de la tarea"
            android:layout_marginTop="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Descripción -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDescripcion"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descripción / Instrucciones"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- File Selector -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionarArchivo"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📎 Seleccionar Archivo (PDF/Word/Excel)"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvArchivoSeleccionado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/md_theme_primary"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <!-- Date Picker -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFechaLimite"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📅 Seleccionar Fecha Límite"
            android:layout_marginTop="12dp" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <!-- Publish Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPublicar"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚀 Publicar Tarea"
            android:textSize="16sp"
            android:layout_marginTop="20dp" />

        <View android:layout_height="32dp" android:layout_width="match_parent" />

    </LinearLayout>
</ScrollView>
